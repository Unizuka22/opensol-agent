{
  "name": "opensol-agent",
  "version": "0.1.0",
  "description": "CLI-first Solana intelligence agent for plain-English wallet, token, and transaction risk reports.",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "opensol": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "solana",
    "risk-analysis",
    "cli",
    "open-source",
    "web3",
    "security"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
